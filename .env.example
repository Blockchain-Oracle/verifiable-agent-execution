# Copy this to .env (which is gitignored) and fill in your own values.
# This file IS committed; .env is NOT.

# --- Wallet ---
# Generate locally with: node -e "console.log(require('ethers').Wallet.createRandom().privateKey)"
# Fund the address at https://faucet.0g.ai (Galileo testnet, 0.1 0G/day)
PRIVATE_KEY=0x_your_testnet_private_key_here

# --- Galileo testnet (build target) ---
ZG_TESTNET_RPC=https://evmrpc-testnet.0g.ai
ZG_TESTNET_CHAIN_ID=16602
ZG_TESTNET_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
ZG_TESTNET_EXPLORER=https://chainscan-galileo.0g.ai
ZG_TESTNET_FAUCET=https://faucet.0g.ai

# --- Mainnet (Aristotle, submission target) ---
ZG_MAINNET_RPC=https://evmrpc.0g.ai
ZG_MAINNET_CHAIN_ID=16661
ZG_MAINNET_INDEXER=https://indexer-storage-turbo.0g.ai
ZG_MAINNET_EXPLORER=https://chainscan.0g.ai

# --- Pre-deployed AgenticID (Galileo) — see context/SOURCE_OF_TRUTH.md ---
