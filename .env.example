# Copy this to .env (which is gitignored) and fill in your own values.
# This file IS committed; .env is NOT.

# --- Wallet ---
# Generate locally with: node -e "console.log(require('ethers').Wallet.createRandom().privateKey)"
# Testnet: fund via https://faucet.0g.ai (0.1 0G/day)
# Mainnet: withdraw 0G from a CEX to the native 0G chain (Aristotle,
#   chainId 16661) — never BSC/ETH OFT for this wallet.
PRIVATE_KEY=0x_your_private_key_here

# --- 0G chain RPC (network-agnostic; one is enough per run) ---
# ZG_RPC is the canonical name (Epic-7). The legacy ZG_TESTNET_RPC alias
# is still accepted by the code as a back-compat fallback so existing
# .env files keep working — but use ZG_RPC for new setups.
#   Galileo testnet:    https://evmrpc-testnet.0g.ai
#   Aristotle mainnet:  https://evmrpc.0g.ai
ZG_RPC=https://evmrpc-testnet.0g.ai

# --- 0G Storage indexer (network-agnostic env name) ---
#   Galileo:    https://indexer-storage-testnet-turbo.0g.ai
#   Mainnet:    https://indexer-storage-turbo.0g.ai
ZG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# --- Active chain ID ---
#   16602 = Galileo testnet
#   16661 = Aristotle mainnet
CHAIN_ID=16602

# --- Contracts (Epic-7 OUR deploys; default to Galileo) ---
# Galileo:
AGENTICID_ADDRESS=0xd4a5eA2501810d7C81464aa3CdBa58Bfded09E38
TEE_VERIFIER_ADDRESS=0x058fc372562D195F1c2356e4DcFfD94de98Ec3ad
# Mainnet override block — swap to these when CHAIN_ID=16661:
#   AGENTICID_ADDRESS=0xC6f7fB1511a7483C6e14258c70529e37ec698937
#   TEE_VERIFIER_ADDRESS=0x4fffB58B488bBeD9f072Ad68EeB77F643b8858D2

# --- TEE oracle signer address (used by deploy-mock when overriding) ---
# Default in deploy-all.ts is now `deployer.address`; set this only if
# you want the verifier to accept signatures from a DIFFERENT key.
# TEE_ORACLE_ADDRESS=0x04581d192d22510ced643eaced12ef169644811a

# --- Cross-network site URLs (for the TopBar's "view <other>" link) ---
# Each Coolify service advertises its sibling deployment via these.
# Defaults assume the subdomain split — verifiable.0g.ai (testnet root)
# and mainnet.verifiable.0g.ai (mainnet subdomain). Override per deploy.
# TESTNET_SITE_URL=https://verifiable.0g.ai
# MAINNET_SITE_URL=https://mainnet.verifiable.0g.ai

# --- Legacy / informational (kept for back-compat) ---
# Older scripts read these explicitly; new code uses ZG_RPC + ZG_INDEXER_RPC.
ZG_TESTNET_RPC=https://evmrpc-testnet.0g.ai
ZG_TESTNET_CHAIN_ID=16602
ZG_TESTNET_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
ZG_TESTNET_EXPLORER=https://chainscan-galileo.0g.ai
ZG_TESTNET_FAUCET=https://faucet.0g.ai
ZG_MAINNET_RPC=https://evmrpc.0g.ai
ZG_MAINNET_CHAIN_ID=16661
ZG_MAINNET_INDEXER=https://indexer-storage-turbo.0g.ai
ZG_MAINNET_EXPLORER=https://chainscan.0g.ai
