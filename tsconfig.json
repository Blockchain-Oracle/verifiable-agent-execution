{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@verifiable-agent-execution/logger": ["packages/logger/src/index.ts"],
      "@verifiable-agent-execution/chain-client": ["packages/chain-client/src/index.ts"],
      "@verifiable-agent-execution/tee-adapter": ["packages/tee-adapter/src/index.ts"]
    }
  },
  "include": [
    "playwright.config.ts",
    "scripts/**/*.ts",
    "scripts/smoke/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/dist",
    "**/.next",
    "packages",
    "contracts",
    "apps"
  ]
}
