# Dashboard env — copy to .env.local for local dev. All four are
# required for the /api/verify/[tokenId] route to resolve a proof.
#
# TEE_VERIFIER_ADDRESS is OPTIONAL — when unset, the dashboard
# operates in "mock" mode (badge shows amber instead of green) so
# the dashboard is usable for storage-only proofs before the
# verifier contract is deployed to mainnet.

ZG_TESTNET_RPC=https://evmrpc-testnet.0g.ai
ZG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
AGENTICID_ADDRESS=0x2700F6A3e505402C9daB154C5c6ab9cAEC98EF1F
CHAIN_ID=16602

# Optional — set after `pnpm hardhat run contracts/scripts/deploy-mock.ts --network 0g-testnet`
# TEE_VERIFIER_ADDRESS=0x...
